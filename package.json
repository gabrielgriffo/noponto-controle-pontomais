{
  "name": "noponto-controle-pontomais",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dist": "electron-builder --publish=never"
  },
  "author": "Gabriel Griffo",
  "license": "MIT",
  "description": "Aplicativo desktop para controle de jornada integrado ao Pontomais: registre horários, monitore progresso e receba notificações inteligentes.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielgriffo/noponto-controle-pontomais.git"
  },
  "keywords": [
    "controle-de-ponto",
    "pontomais",
    "jornada-de-trabalho",
    "desktop-app",
    "electron"
  ],
  "bugs": {
    "url": "https://github.com/gabrielgriffo/noponto-controle-pontomais/issues"
  },
  "homepage": "https://github.com/gabrielgriffo/noponto-controle-pontomais#readme",
  "devDependencies": {
    "electron": "^39.2.0",
    "electron-builder": "26.2.0"
  },
  "dependencies": {
    "electron-updater": "6.7.1"
  },
  "build": {
    "appId": "com.gabrielgriffo.noponto",
    "productName": "No Ponto",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "No Ponto",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerHeader": "build/headerBackground.bmp",
      "installerSidebar": "build/background.bmp"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "gabrielgriffo",
        "repo": "noponto-controle-pontomais"
      }
    ]
  }
}
